# Slack 설정
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_APP_TOKEN=xapp-your-slack-app-token   # Socket Mode 용 (connections:write 스코프)
SLACK_CHANNEL=#hermes

# 에이전트 설정
CHECK_INTERVAL_SECONDS=60       # 위치 체크 주기 (초)
PROXIMITY_RADIUS_METERS=500     # 알림 반경 (미터)
AREA_RADIUS_METERS=1000         # 지역명 검색 반경 (미터)

# 고정 위치 (설정 시 IP 기반 위치 대신 사용 — '주변 맛집' 정확도 향상)
# HOME_LAT=37.4878
# HOME_LNG=126.9803
